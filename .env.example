# Vorlage. Kopieren nach .env (setup.sh erledigt das mit --install).
# .env ist gitignored und enthaelt lokale Werte/Secrets.

# --- Postgres (Docker-Compose-Dienst) ---
POSTGRES_USER=stratum
POSTGRES_PASSWORD=stratum
POSTGRES_DB=stratum
POSTGRES_PORT=5432
# Verbindung aus dem WSL2-Kern (nativ) auf den Compose-Port:
DATABASE_URL=postgresql://stratum:stratum@localhost:5432/stratum
# POSTGRES_HOST wird im server-Container automatisch auf "db" überschrieben
# (docker-compose.yml environment-Sektion), hier nicht ändern nötig.

# --- Ollama (laeuft nativ auf dem Windows-Host) ---
# setup.sh ermittelt die Windows-Host-IP automatisch (WSL2-Default-Route).
# Port 11434 muss in der Windows-Firewall freigegeben sein (als Admin):
#   netsh advfirewall firewall add rule name="Ollama WSL2" dir=in action=allow protocol=TCP localport=11434
# Aus einem Docker-Container stattdessen: http://host.docker.internal:11434
# Im Docker-Container statt localhost:
# OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_HOST=http://localhost:11434

# --- Anthropic (erst ab Schritt 3 / N3 noetig) ---
ANTHROPIC_API_KEY=
