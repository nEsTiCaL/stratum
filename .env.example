# Vorlage. Kopieren nach .env (setup.sh erledigt das mit --install).
# .env ist gitignored und enthaelt lokale Werte/Secrets.

# --- Postgres (Docker-Compose-Dienst) ---
POSTGRES_USER=stratum
POSTGRES_PASSWORD=stratum
POSTGRES_DB=stratum
POSTGRES_PORT=5432
# Verbindung aus dem WSL2-Kern (nativ) auf den Compose-Port:
DATABASE_URL=postgresql://stratum:stratum@localhost:5432/stratum

# --- Ollama (laeuft nativ auf dem Windows-Host) ---
# Mit WSL2 Mirrored Networking (.wslconfig networkingMode=mirrored) ist
#   localhost aus WSL2 direkt der Windows-Host -> kein Firewall-Aufwand.
# Ohne Mirrored Networking: Windows-Host-IP (setup.sh ermittelt sie).
# Aus einem Docker-Container: http://host.docker.internal:11434
OLLAMA_HOST=http://localhost:11434

# --- Anthropic (erst ab Schritt 3 / N3 noetig) ---
ANTHROPIC_API_KEY=
