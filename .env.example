# Vorlage. Kopieren nach .env (setup.sh erledigt das mit --install).
# .env ist gitignored und enthaelt lokale Werte/Secrets.

# --- Postgres (Docker-Compose-Dienst) ---
POSTGRES_USER=stratum
POSTGRES_PASSWORD=stratum
POSTGRES_DB=stratum
POSTGRES_PORT=5432
# Verbindung aus dem WSL2-Kern (nativ) auf den Compose-Port:
DATABASE_URL=postgresql://stratum:stratum@localhost:5432/stratum
# POSTGRES_HOST wird im server-Container automatisch auf "db" überschrieben
# (docker-compose.yml environment-Sektion), hier nicht ändern nötig.

# --- Ollama (laeuft als systemd-Dienst in WSL2) ---
# Aus WSL-nativ (pytest, devcli): localhost:11434
# Aus Docker-Container: host.docker.internal:11434 (in docker-compose.yml vorkonfiguriert,
#   hier nicht aendern noetig; setzt OLLAMA_HOST=0.0.0.0 im ollama-Dienst voraus).
# setup.sh prueft und konfiguriert 0.0.0.0-Bindung automatisch.
OLLAMA_HOST=http://localhost:11434

# --- Anthropic (erst ab Schritt 3 / N3 noetig) ---
ANTHROPIC_API_KEY=
