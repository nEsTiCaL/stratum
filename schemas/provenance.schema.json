{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "provenance.schema.json",
  "title": "Provenance",
  "description": "Herkunftsnachweis eines Artefakts. Klebt an jedem Artefakt, identisch fuer det und prob.",
  "type": "object",
  "required": [
    "schema_version",
    "source_hash",
    "input_hash",
    "producer",
    "producer_version",
    "producer_class",
    "timestamp",
    "artifact_type",
    "scope"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema-Version fuer Interpretierbarkeit alter Artefakte"
    },
    "source_hash": {
      "type": "string",
      "description": "commit_hash oder worktree_hash des Quell-Repo"
    },
    "input_hash": {
      "type": "string",
      "description": "Content-Hash der Eingabe (Staleness-Lookup)"
    },
    "producer": {
      "type": "string",
      "description": "Bezeichner des Erzeugers, z.B. tree-sitter-py oder qwen2.5-coder"
    },
    "producer_version": {
      "type": "string",
      "description": "Tool- oder Modellversion"
    },
    "producer_class": {
      "type": "string",
      "enum": ["det", "prob"],
      "description": "det = deterministisch, prob = probabilistisch (LLM)"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Erzeugungszeit (ISO 8601 mit Zeitzone)"
    },
    "artifact_type": {
      "type": "string",
      "enum": [
        "symbol_index",
        "dependency_graph",
        "call_graph",
        "code_summary",
        "code_explanation",
        "review_findings",
        "refactor_plan",
        "debug_analysis",
        "test_generation",
        "docstring"
      ],
      "description": "Typ des Artefakts. Geschlossene Enum ueber S1-S5, vorgebaut."
    },
    "scope": {
      "type": "string",
      "pattern": "^([A-Za-z0-9_.-]+::)?(repo|file|module|symbol):[^#]*(#[A-Za-z0-9_.]+(/[0-9]+)?)?$",
      "description": "Scope-Schluessel: [repo-id::]typ:pfad[#symbolpfad[/arity]]"
    }
  }
}
