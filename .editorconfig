# Einheitliche Kodierung/Zeilenenden ueber Editoren hinweg.
# Ziel: Windows-Dev erzeugt schon Linux-konforme Dateien.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{js,ts,json,yml,yaml,toml,scm,html,css}]
indent_size = 2

[*.go]
indent_style = tab

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false

[*.{bat,cmd,ps1}]
end_of_line = crlf
